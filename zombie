local function removeESPFor(id)
    local e = ESPRegistry[id]; if not e then return end
    if e.esp and e.esp.Parent then e.esp:Destroy() end
    if e.box and e.box.Parent then e.box:Destroy() end
    ESPRegistry[id] = nil
end

local function enableESP()
    if not IS_MAIN then Toast("Only in Main Game!") return end
    ESP.enabled = true
    if ZombieTable then
        for id, data in pairs(ZombieTable) do
            if data.IsDying or (data.Health or 1) <= 0 then continue end
            if data.Model and data.Model.Parent then
                pcall(function() createESPFor(id, data.Model, data.Humanoid) end)
            end
        end
    end
    local function scanFolder(folder)
        if not folder then return end
        for _, child in ipairs(folder:GetChildren()) do
            local nid = tonumber(child.Name:match("^Zombie_(%d+)$"))
            if nid and not ESPRegistry[nid] then
                pcall(function()
                    createESPFor(nid, child, child:FindFirstChildOfClass("Humanoid"))
                end)
            end
        end
    end
    scanFolder(workspace:FindFirstChild("Zombies_Local"))
    scanFolder(workspace:FindFirstChild("FriendlyZombies"))
    Toast("Zombie ESP ENABLED")
end

local function disableESP()
    ESP.enabled = false
    for id, _ in pairs(ESPRegistry) do removeESPFor(id) end
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name == "_ESPBox" then pcall(function() obj:Destroy() end) end
    end
    Toast("Zombie ESP DISABLED")
end

RunService.Heartbeat:Connect(function()
    if not ESP.enabled then return end
    ESP.frameCount = ESP.frameCount + 1
    if ESP.frameCount % ESP.UPDATE_EVERY ~= 0 then return end
    local hrp = getHRP()
    local myPos = hrp and hrp.Position or Vector3.zero
    for id, e in pairs(ESPRegistry) do
        if not (e.hrp and e.hrp.Parent) then removeESPFor(id) continue end
        local data = ZombieTable and ZombieTable[id]
        if data and (data.IsDying or (data.Health or 1) <= 0) then
            removeESPFor(id) continue
        end
        if e.humanoid and e.humanoid.Health <= 0 then
            removeESPFor(id) continue
        end
        local dist = math.floor((e.hrp.Position - myPos).Magnitude)
        e.distLbl.Text = dist .. " studs"
        e.distLbl.TextColor3 = dist < 20 and Color3.fromRGB(255,80,80)
            or dist < 60 and Color3.fromRGB(255,200,60)
            or Color3.fromRGB(120,220,120)
        if data and data.MaxHealth and data.MaxHealth > 0 then
            local ratio = math.clamp(data.Health / data.MaxHealth, 0, 1)
            e.hpFill.Size = UDim2.new(ratio, 0, 1, 0)
            e.hpFill.BackgroundColor3 = Color3.fromRGB(
                math.floor(255*(1-ratio)), math.floor(255*ratio), 40)
        end
    end
    if ZombieTable then
        for id, data in pairs(ZombieTable) do
            if not ESPRegistry[id] and not data.IsDying and (data.Health or 1) > 0 then
                if data.Model and data.Model.Parent then
                    pcall(function() createESPFor(id, data.Model, data.Humanoid) end)
                end
            end
        end
    end
end)

