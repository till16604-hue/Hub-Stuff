-- AUTO SHOP
-- ═══════════════════════════════════════════════════════════
local AutoShop = {
    healthEnabled = false, weaponEnabled = false,
    healthThread  = nil,   weaponThread  = nil,
    healthCount   = 0,     weaponCount   = 0,
}
local HEALTH_REMOTE_NAMES = {
    "PurchaseHealthUpgrade","BuyHealth","UpgradeHealth","HealthUpgrade","PurchaseHealth",
    "BuyMaxHealth","UpgradeMaxHealth","Health","ShopBuyHealth",
    "BuyItem","PurchaseItem","Shop","Upgrade","Buy",
}
local WEAPON_REMOTE_NAMES = {
    "PurchaseWeaponUpgrade","PurchaseDamageUpgrade","BuyWeapon","UpgradeWeapon",
    "WeaponUpgrade","PurchaseWeapon","BuyGun","UpgradeGun","Weapon","ShopBuyWeapon",
    "BuyItem","PurchaseItem","Shop","Upgrade","Buy",
}
local function findRemotesByNames(names)
    local found = {}
    for _, name in ipairs(names) do
        for _, obj in ipairs(ReplicatedStorage:GetDescendants()) do
            if obj.Name:lower() == name:lower() and
               (obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction")) then
                table.insert(found, obj)
            end
        end
    end
    return found
end
local function fireShopRemote(remote, ...)
    local args = {...}
    if remote:IsA("RemoteEvent") then
        pcall(function() remote:FireServer(table.unpack(args)) end)
    elseif remote:IsA("RemoteFunction") then
        pcall(function() remote:InvokeServer(table.unpack(args)) end)
    end
end
local CachedHealthRemotes, CachedWeaponRemotes = nil, nil
local function doHealthBuy()
    if not CachedHealthRemotes then
        CachedHealthRemotes = findRemotesByNames(HEALTH_REMOTE_NAMES)
    end
    local args = {
        "Health","MaxHealth","UpgradeHealth","HealthUpgrade",
        "BuyHealth",1,2,"Upgrade","Buy",true,"HP"
    }
    for _, rem in ipairs(CachedHealthRemotes) do
        fireShopRemote(rem)
        for _, arg in ipairs(args) do
            fireShopRemote(rem, arg)
            fireShopRemote(rem, arg, 1)
        end
    end
end
local function doWeaponBuy()
    if not CachedWeaponRemotes then
        CachedWeaponRemotes = findRemotesByNames(WEAPON_REMOTE_NAMES)
    end
    local args = {
        "Weapon","Damage","UpgradeWeapon","WeaponUpgrade",
        "BuyWeapon","Gun",1,2,"Upgrade","Buy",true
    }
    for _, rem in ipairs(CachedWeaponRemotes) do
        fireShopRemote(rem)
        for _, arg in ipairs(args) do
            fireShopRemote(rem, arg)
            fireShopRemote(rem, arg, 1)
        end
    end
end
local function startAutoHealth()
    if not IS_ARENA then Toast("Only in Arena!") return end
    AutoShop.healthEnabled = true
    Toast("Auto Health ENABLED")
    AutoShop.healthThread = task.spawn(function()
        while AutoShop.healthEnabled do
            doHealthBuy()
            AutoShop.healthCount = AutoShop.healthCount + 1
            task.wait(1.5)
        end
    end)
end
local function stopAutoHealth()
    AutoShop.healthEnabled = false
    AutoShop.healthThread  = nil
    Toast("Auto Health DISABLED")
end
local function startAutoWeapon()
    if not IS_ARENA then Toast("Only in Arena!") return end
    AutoShop.weaponEnabled = true
    Toast("Auto Weapon ENABLED")
    AutoShop.weaponThread = task.spawn(function()
        while AutoShop.weaponEnabled do
            doWeaponBuy()
            AutoShop.weaponCount = AutoShop.weaponCount + 1
            task.wait(1.5)
        end
    end)
end
local function stopAutoWeapon()
    AutoShop.weaponEnabled = false
    AutoShop.weaponThread  = nil
    Toast("Auto Weapon DISABLED")
end

