-- ═══════════════════════════════════════════════════════════
local ZombieTable = nil

local function findZombieTable()
    pcall(function()
        local scripts = LP:FindFirstChild("PlayerScripts")
        if scripts then
            local ctrl = scripts:FindFirstChild("Controllers", true)
                or scripts:FindFirstChild("ZombieClient", true)
            if ctrl then
                local ok, mod = pcall(require, ctrl)
                if ok and mod and type(mod.Zombies) == "table" then
                    ZombieTable = mod.Zombies
                end
            end
        end
    end)
    if not ZombieTable then
        pcall(function()
            for _, v in pairs(getgc(true)) do
                if type(v) == "table"
                    and rawget(v, "Zombies")
                    and rawget(v, "ZombieModels")
                    and type(rawget(v, "Zombies")) == "table"
                then
                    ZombieTable = v.Zombies
                    break
                end
            end
        end)
    end
    return ZombieTable
end

task.spawn(function()
    task.wait(1)
    findZombieTable()
    if not ZombieTable then
        task.wait(2)
        findZombieTable()
    end
end)

