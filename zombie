-- WAVE SKIP
-- ═══════════════════════════════════════════════════════════
local WaveSkip = { autoEnabled = false, skipCount = 0, thread = nil }
local SKIP_REMOTE_NAMES = {
    "SkipWave","VoteSkip","NextWave","SkipRound","VoteNextWave",
    "SkipVote","WaveSkip","SkipWaveVote","RequestSkip","SkipRequest",
    "WaveVote","Vote","Skip",
}

local function findSkipRemote()
    for _, name in ipairs(SKIP_REMOTE_NAMES) do
        local r = ReplicatedStorage:FindFirstChild(name, true)
        if r and (r:IsA("RemoteEvent") or r:IsA("RemoteFunction")) then return r end
    end
    local er = ReplicatedStorage:FindFirstChild("EventRemotes")
    if er then
        for _, child in ipairs(er:GetChildren()) do
            local n = child.Name:lower()
            if n:find("skip") or n:find("wave") or n:find("next") or n:find("vote") then
                return child
            end
        end
    end
    return nil
end

local function doSkipWave()
    if not IS_ARENA then Toast("Only in Arena!") return end
    local remote = findSkipRemote()
    local fired = false
    if remote then
        if remote:IsA("RemoteEvent") then
            pcall(function() remote:FireServer() end)
            pcall(function() remote:FireServer(true) end)
        elseif remote:IsA("RemoteFunction") then
            pcall(function() remote:InvokeServer() end)
        end
        fired = true
    end
    for _, gui in ipairs(LP.PlayerGui:GetDescendants()) do
        if gui:IsA("TextButton") or gui:IsA("ImageButton") then
            local t = (gui.Name .. " " .. (gui:IsA("TextButton") and gui.Text or "")):lower()
            if t:find("skip") or t:find("next.*wave") or t:find("wave.*skip") or t:find("vote") then
                pcall(function() gui.MouseButton1Click:Fire() end)
                pcall(function() gui.Activated:Fire() end)
                fired = true
            end
        end
    end
    WaveSkip.skipCount = WaveSkip.skipCount + 1
end

local function startAutoWaveSkip()
    if not IS_ARENA then Toast("Only in Arena!") return end
    WaveSkip.autoEnabled = true
    Toast("Auto Wave Skip ENABLED")
    WaveSkip.thread = task.spawn(function()
        while WaveSkip.autoEnabled do doSkipWave(); task.wait(0.05) end
    end)
end

local function stopAutoWaveSkip()
    WaveSkip.autoEnabled = false
    WaveSkip.thread = nil
    Toast("Auto Wave Skip DISABLED")
end

