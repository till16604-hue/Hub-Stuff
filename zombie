-- CHARACTER ADDED
-- ═══════════════════════════════════════════════════════════
table.insert(GlobalConnections, LP.CharacterAdded:Connect(function(char)
    char:WaitForChild("HumanoidRootPart"); task.wait(0.5)
    if Fly.enabled then
        flyDisable()
        local t = UI.GetToggle("FlyToggle"); if t then t.SetSilent(false) end
    end
    if Noclip.enabled then
        noclipDisable()
        local t = UI.GetToggle("NoclipToggle"); if t then t.SetSilent(false) end
    end
    if Kill.autoEnabled then
        stopAutoKill()
        local t = UI.GetToggle("AutoKillToggle"); if t then t.SetSilent(false) end
    end
    if SafeZone.enabled then
        task.wait(0.3)
        local bp = Instance.new("BodyPosition")
        bp.Name = "SafeZoneBP"; bp.MaxForce = Vector3.new(0, math.huge, 0)
        bp.Position = Vector3.new(0, SafeZone.lockedY, 0)
        local root = char:FindFirstChild("HumanoidRootPart")
        if root then bp.Parent = root end
    end
    if GodMode.enabled then
        if GodMode.conn then GodMode.conn:Disconnect() end
        GodMode.enabled = false; godEnable()
    end
    if InfJump.enabled then
        if InfJump.conn then InfJump.conn:Disconnect() end
        InfJump.enabled = false; infJumpEnable()
    end
    if SpeedHack.enabled then task.wait(0.2); speedEnable() end
end))

