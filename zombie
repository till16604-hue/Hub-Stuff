-- ═══════════════════════════════════════════════════════════
local Fly = { enabled = false, speed = 60, bv = nil, bg = nil, conn = nil }

local function flyEnable()
    local hrp = getHRP(); local hum = getHum()
    if not hrp or not hum then Toast("No character!") return end
    hum.PlatformStand = true
    local bv = Instance.new("BodyVelocity")
    bv.Name = "_FlyBV"; bv.Velocity = Vector3.zero
    bv.MaxForce = Vector3.new(1e6,1e6,1e6); bv.P = 1e4; bv.Parent = hrp
    Fly.bv = bv
    local bg = Instance.new("BodyGyro")
    bg.Name = "_FlyBG"; bg.MaxTorque = Vector3.new(1e6,1e6,1e6)
    bg.P = 1e4; bg.D = 100; bg.CFrame = hrp.CFrame; bg.Parent = hrp
    Fly.bg = bg
    Fly.conn = RunService.RenderStepped:Connect(function()
        local h2 = getHRP(); if not h2 then return end
        local cam = workspace.CurrentCamera; if not cam then return end
        local dir = Vector3.zero; local spd = Fly.speed
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then spd = spd * 2.5 end
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.E) or
           UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.new(0,1,0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.Q) then dir = dir - Vector3.new(0,1,0) end
        if dir.Magnitude > 0 then dir = dir.Unit end
        if Fly.bv and Fly.bv.Parent then Fly.bv.Velocity = dir * spd end
        if Fly.bg and Fly.bg.Parent then Fly.bg.CFrame = cam.CFrame end
    end)
    Fly.enabled = true
    Toast("Fly ENABLED")
end

local function flyDisable()
    local hum = getHum(); if hum then hum.PlatformStand = false end
    if Fly.bv and Fly.bv.Parent then Fly.bv:Destroy() end
    if Fly.bg and Fly.bg.Parent then Fly.bg:Destroy() end
    if Fly.conn then Fly.conn:Disconnect(); Fly.conn = nil end
    Fly.bv = nil; Fly.bg = nil; Fly.enabled = false
    Toast("Fly DISABLED")
end

