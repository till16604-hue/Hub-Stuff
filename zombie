task.defer(function()
    task.wait(0.5)
    local shouldAutoLoad = false
    if readfile and isfile and HttpService then
        pcall(function()
            if isfile(CONFIG_FILE) then
                local data = HttpService:JSONDecode(readfile(CONFIG_FILE))
                if type(data) == "table" and data["CfgAutoLoadToggle"] == true then
                    shouldAutoLoad = true
                end
            end
        end)
    end
    if shouldAutoLoad then
        task.wait(0.3)
        loadConfig(false)
        Toast("Config auto-loaded!")
    end
    task.wait(0.5)
    local fl = UI.GetLabel("CfgFileStatus")
    if fl then
        if isfile and isfile(CONFIG_FILE) then
            fl.SetValue("Found: " .. CONFIG_NAME)
        else
            fl.SetValue("No file found")
        end
    end
    local kl = UI.GetLabel("CfgKeysCount")
    if kl then
        local n = 0; for _ in pairs(ConfigRegistry) do n = n + 1 end
        kl.SetValue(tostring(n) .. " entries")
    end
end)

