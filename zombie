-- ═══════════════════════════════════════════════════════════
-- VOID SHARD MAGNET
-- ═══════════════════════════════════════════════════════════
local VoidMagnet = {
    enabled     = false,
    collected   = 0,
    folderConns = {},
    countLabel  = nil,
}
local VoidMagnet_seen = {}

local function tryCollectShard(obj)
    if not obj or not obj.Parent then return end
    if VoidMagnet_seen[obj] then return end
    VoidMagnet_seen[obj] = true
    local hrp = getHRP()
    if not hrp then VoidMagnet_seen[obj] = nil return end
    local part = nil
    if obj:IsA("BasePart") then
        part = obj
    elseif obj:IsA("Model") then
        pcall(function() part = obj:WaitForChild("VoidShardPart", 3) end)
        if not part then part = obj:FindFirstChildWhichIsA("BasePart") end
    end
    if not part then part = obj:FindFirstChild("VoidShardPart", true) end
    if not part or not part.Parent then return end
    local allParts = {}
    if obj:IsA("Model") then
        for _, child in ipairs(obj:GetDescendants()) do
            if child:IsA("BasePart") then table.insert(allParts, child) end
        end
    end
    if #allParts == 0 then table.insert(allParts, part) end
    local container = obj:IsA("Model") and obj
        or (obj.Parent and obj.Parent:IsA("Model") and obj.Parent) or nil
    local collectRemote = nil
    local remoteNames = {
        "CollectVoidShard","VoidShardCollect","CollectShard",
        "VoidCollect","ShardCollect","PickupShard","Collect",
    }
    for _, name in ipairs(remoteNames) do
        local rem = ReplicatedStorage:FindFirstChild(name, true)
        if rem and rem:IsA("RemoteEvent") then collectRemote = rem; break end
    end
    for attempt = 1, 15 do
        if not obj.Parent then break end
        local hrp2 = getHRP(); if not hrp2 then break end
        local targetCF = CFrame.new(hrp2.Position + Vector3.new(0, 3, 0))
        for _, p in ipairs(allParts) do pcall(function() p.CFrame = targetCF end) end
        task.wait(0.03)
        for _, p in ipairs(allParts) do
            if p.Parent then
                pcall(function() firetouchinterest(hrp2, p, 0) end)
                pcall(function() firetouchinterest(hrp2, p, 1) end)
            end
        end
        if container then
            for _, child in ipairs(container:GetDescendants()) do
                if child:IsA("ProximityPrompt") then
                    pcall(function() fireproximityprompt(child) end)
                end
            end
        end
        if collectRemote then pcall(function() collectRemote:FireServer() end) end
        task.wait(0.15)
        if not obj.Parent then break end
    end
    if not obj.Parent then
        VoidMagnet.collected = VoidMagnet.collected + 1
        if VoidMagnet.countLabel then
            VoidMagnet.countLabel.SetValue(VoidMagnet.collected .. " collected")
        end
        Toast("Void Shard #" .. VoidMagnet.collected .. " collected!")
    else
        VoidMagnet_seen[obj] = nil
    end
end

local VoidMagnet_pollFrame = 0

local function watchShardFolder(folder)
    if not folder then return end
    for _, child in ipairs(folder:GetChildren()) do
        if VoidMagnet.enabled then
            task.spawn(function() tryCollectShard(child) end)
        end
    end
    local connAdd = folder.ChildAdded:Connect(function(child)
        if not VoidMagnet.enabled then return end
        if VoidMagnet_seen[child] then return end
        task.wait(0.15)
        task.spawn(function() tryCollectShard(child) end)
    end)
    table.insert(VoidMagnet.folderConns, connAdd)
    local connRem = folder.ChildRemoved:Connect(function(child)
        VoidMagnet_seen[child] = nil
    end)
    table.insert(VoidMagnet.folderConns, connRem)
    local connPoll = RunService.Heartbeat:Connect(function()
        if not VoidMagnet.enabled then return end
        VoidMagnet_pollFrame = VoidMagnet_pollFrame + 1
        if VoidMagnet_pollFrame % 30 ~= 0 then return end
        if not folder.Parent then return end
        for _, child in ipairs(folder:GetChildren()) do
            if not VoidMagnet_seen[child] then
                task.spawn(function() tryCollectShard(child) end)
            end
        end
    end)
    table.insert(VoidMagnet.folderConns, connPoll)
end

local function enableVoidMagnet()
    if not IS_MAIN then Toast("Only in Main Game!") return end
    VoidMagnet.enabled = true
    Toast("Void Magnet ENABLED")
    watchShardFolder(workspace:FindFirstChild("VoidShards"))
    local c = workspace.ChildAdded:Connect(function(child)
        if child.Name == "VoidShards" and VoidMagnet.enabled then
            task.wait(0.1)
            watchShardFolder(child)
        end
    end)
    table.insert(VoidMagnet.folderConns, c)
end

local function disableVoidMagnet()
    VoidMagnet.enabled = false
    for _, c in ipairs(VoidMagnet.folderConns) do
        pcall(function() c:Disconnect() end)
    end
    VoidMagnet.folderConns = {}
    Toast("Void Magnet DISABLED")
end

