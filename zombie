-- ═══════════════════════════════════════════════════════════
-- CONFIG SYSTEM
-- ═══════════════════════════════════════════════════════════
local ConfigRegistry = {}

local function registerConfigToggle(id, getterFn, setterFn)
    ConfigRegistry[id] = { type = "toggle", get = getterFn, set = setterFn }
end

local function registerConfigSlider(id, getterFn, setterFn)
    ConfigRegistry[id] = { type = "slider", get = getterFn, set = setterFn }
end

local function saveConfig()
    if not (writefile and HttpService) then
        Toast("writefile not available!")
        return false
    end
    local data = {}
    for id, entry in pairs(ConfigRegistry) do
        data[id] = entry.get()
    end
    local ok, err = pcall(function()
        writefile(CONFIG_FILE, HttpService:JSONEncode(data))
    end)
    if ok then
        Toast("Config saved!")
        return true
    else
        Toast("Save failed: " .. tostring(err))
        return false
    end
end

local function loadConfig(silent)
    if not (readfile and isfile and HttpService) then
        if not silent then Toast("readfile not available!") end
        return false
    end
    local ok, data = pcall(function()
        if not isfile(CONFIG_FILE) then error("no file") end
        return HttpService:JSONDecode(readfile(CONFIG_FILE))
    end)
    if not ok or type(data) ~= "table" then
        if not silent then Toast("No config found or parse error!") end
        return false
    end
    for id, value in pairs(data) do
        local entry = ConfigRegistry[id]
        if entry then
            pcall(function() entry.set(value) end)
        end
    end
    if not silent then Toast("Config loaded!") end
    return true
end

