-- ═══════════════════════════════════════════════════════════
-- KILL ENGINE
-- ═══════════════════════════════════════════════════════════
local Kill = {
    autoEnabled = false,
    loopThread  = nil,
    killed      = 0,
    countLabel  = nil,
}
local Kill_lastAlive = {}

local function killAllZombies()
    local remote = getDmgRemote()
    if not remote then return 0 end
    if not ZombieTable then findZombieTable() end
    local currentAlive = {}
    local fired = 0
    if ZombieTable then
        for id, data in pairs(ZombieTable) do
            if data and not data.IsDying and (data.Health or 0) > 0 then
                currentAlive[id] = true
                for i = 1, 3 do
                    pcall(function() remote:FireServer(id, math.huge) end)
                end
                fired = fired + 1
            end
        end
    end
    if fired == 0 then
        local folders = {
            workspace:FindFirstChild("Zombies_Local"),
            workspace:FindFirstChild("FriendlyZombies"),
        }
        for _, folder in ipairs(folders) do
            if folder then
                for _, child in ipairs(folder:GetChildren()) do
                    local id = tonumber(child.Name:match("^Zombie_(%d+)$"))
                    if id then
                        currentAlive[id] = true
                        for i = 1, 3 do
                            pcall(function() remote:FireServer(id, math.huge) end)
                        end
                        local hum = child:FindFirstChildOfClass("Humanoid")
                        if hum then pcall(function() hum.Health = 0 end) end
                        fired = fired + 1
                    end
                end
            end
        end
    end
    local deaths = 0
    for id in pairs(Kill_lastAlive) do
        if not currentAlive[id] then deaths = deaths + 1 end
    end
    Kill_lastAlive = currentAlive
    return deaths
end

local function killOnce()
    local remote = getDmgRemote()
    if not remote then Toast("No ZombieDamage remote found!") return end
    if not ZombieTable then findZombieTable() end
    local n = 0
    if ZombieTable then
        for id, data in pairs(ZombieTable) do
            if data and not data.IsDying and (data.Health or 0) > 0 then
                pcall(function() remote:FireServer(id, math.huge) end)
                n = n + 1
            end
        end
    end
    Toast("Kill All fired at " .. n .. " zombies")
end

local function startAutoKill()
    Kill.autoEnabled = true
    Kill_lastAlive   = {}
    Toast("Auto-Kill ENABLED")
    Kill.loopThread = task.spawn(function()
        while Kill.autoEnabled do
            local deaths = killAllZombies()
            Kill.killed  = Kill.killed + deaths
            if Kill.countLabel then
                Kill.countLabel.SetValue(Kill.killed .. " killed")
            end
            task.wait(0.2)
        end
    end)
end

local function stopAutoKill()
    Kill.autoEnabled = false
    Kill.loopThread  = nil
    Kill_lastAlive   = {}
    Toast("Auto-Kill DISABLED")
end

